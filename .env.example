# Vellbeing OS - Environment Variables Template
# Copy this file to .env and fill in the values

# ========================
# JWT Configuration
# ========================
# REQUIRED: Generate a secure 256-bit (32+ char) random string
# Example: openssl rand -base64 32
JWT_SECRET=your-secure-256-bit-secret-key-here

# ========================
# Email Configuration
# ========================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@vellbeing.app

# ========================
# External APIs
# ========================
# USDA FoodData Central API
# Get your key at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your-usda-api-key

# Alpha Vantage API (for market data)
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# ========================
# CORS (Production)
# ========================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# ========================
# Frontend URL (for email links)
# ========================
FRONTEND_URL=http://localhost:5000
